<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FF0000" <!-- 红色背景 -->
    android:padding="16dp"
    tools:context=".MainActivity">

    <ImageView
        android:id="@+id/quoteImage"
        android:layout_width="match_parent"
        android:layout_height="200dp"
        android:src="@drawable/quote_background"
        android:layout_marginBottom="16dp"
        android:scaleType="centerInside"/>

    <TextView
        android:id="@+id/quoteText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="点击下方按钮抽取今日卡牌"
        android:textColor="#FFFFFF" <!-- 白色文字 -->
        android:textSize="24sp"
        android:layout_below="@id/quoteImage"
        android:gravity="center"
        android:layout_marginBottom="32dp"
        android:padding="16dp"
        android:background="@drawable/quote_background"
        android:textStyle="bold"/>

    <Button
        android:id="@+id/favoriteButton"
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:text="收藏"
        android:textColor="#FFFFFF"
        android:background="#CC0000" <!-- 深红色按钮 -->
        android:layout_below="@id/quoteImage"
        android:layout_alignParentEnd="true"
        android:layout_marginEnd="16dp"
        android:textSize="16sp"/>

    <Button
        android:id="@+id/shareButton"
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:text="分享"
        android:textColor="#FFFFFF"
        android:background="#CC0000" <!-- 深红色按钮 -->
        android:layout_below="@id/quoteImage"
        android:layout_toStartOf="@id/favoriteButton"
        android:layout_marginEnd="16dp"
        android:textSize="16sp"/>

    <Button
        android:id="@+id/historyButton"
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:text="历史"
        android:textColor="#FFFFFF"
        android:background="#CC0000" <!-- 深红色按钮 -->
        android:layout_below="@id/quoteImage"
        android:layout_toStartOf="@id/shareButton"
        android:layout_marginEnd="16dp"
        android:textSize="16sp"/>

    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true"
        android:visibility="gone"/>

    <Button
        android:id="@+id/drawCardButton"
        android:layout_width="200dp"
        android:layout_height="80dp"
        android:text="抽取今日卡牌"
        android:textColor="#FFFFFF"
        android:background="#CC0000" <!-- 深红色按钮 -->
        android:layout_below="@id/quoteText"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="32dp"
        android:textSize="18sp"/>

</RelativeLayout>